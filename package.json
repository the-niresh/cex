{
  "name": "cex",
  "private": true,
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter backend --filter engine dev",
    "lint": "bun run --filter '*' lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "bun run --filter '*' check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
